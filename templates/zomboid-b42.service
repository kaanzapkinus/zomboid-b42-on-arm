[Unit]
Description=Project Zomboid B42 Dedicated Server (box64/ARM)
After=network-online.target zomboid-ciopfs.service
Wants=network-online.target
Requires=zomboid-ciopfs.service

[Service]
Type=simple
User=__USER__
WorkingDirectory=__INSTALL_DIR__
# box64 tuning for the JVM. These are inherited by the java CHILD process (where the JVM/JIT
# actually runs and crashes happen) — box64 matches config by process name, so the launcher's
# rcfile section does NOT reach java; the environment does.
#   BOX64_JVM=0 turns OFF box64's libjvm auto-detection. That auto-detection otherwise FORCES
#   STRONGMEM=1 (a documented source of random JIT-code SIGSEGVs — box64 issue #2041). With it
#   off we set the JVM-safe values ourselves:
#     STRONGMEM=3  — more memory barriers => far fewer weak-memory crashes than the forced 1
#     BIGBLOCK=0   — smaller dynarec blocks, required for the JVM's self-modifying JIT code
Environment=BOX64_DYNAREC_STRONGMEM=3
Environment=BOX64_DYNAREC_BIGBLOCK=0
Environment=BOX64_DYNAREC_SAFEFLAGS=2
Environment=BOX64_DYNAREC_ALIGNED_ATOMICS=1
Environment=BOX64_JVM=0
Environment=BOX64_SSE42=0
Environment=BOX64_MAXCPU=4
Environment=BOX64_LOG=0
ExecStart=/bin/bash __INSTALL_DIR__/start-server.sh -servername servertest -adminpassword __ADMIN_PW__
# start-server.sh always exits 0, masking JVM crashes, so `always` (not on-failure) is required.
Restart=always
RestartSec=20
TimeoutStopSec=120
KillSignal=SIGTERM

[Install]
WantedBy=multi-user.target
